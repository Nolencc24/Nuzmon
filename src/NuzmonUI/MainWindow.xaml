<Window x:Class="NuzmonUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NuzmonUI"
        xmlns:UserControls="clr-namespace:NuzmonUI.View.UserControls"
        xmlns:NuzlockePage="clr-namespace:NuzmonUI.View.UserControls.NuzlockePage"
        mc:Ignorable="d"
        Title="MainWindow" Height="480" Width="640">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25"/>
            <RowDefinition Height="440"/>
        </Grid.RowDefinitions>
        <UserControls:MenuBar Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <NuzlockePage:PartyViewer Grid.Column="1"/>
        </Grid>

    </Grid>
</Window>
